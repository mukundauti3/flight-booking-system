# =============================================
# SkyBooker — Production .env.example
# Copy to .env and fill in your values
# =============================================

# ----- Server -----
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5173

# ----- Database (MySQL) -----
# DATABASE_URL=mysql://root:root@localhost:3306/skybooker_db
# Or individual vars:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skybooker_db
DB_USER=root
DB_PASSWORD=root

# ----- JWT -----
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# ----- Payment Microservice (.NET) -----
PAYMENT_SERVICE_URL=http://localhost:7000
PAYMENT_SERVICE_API_KEY=sk_internal_key_change_in_production

# ----- Email (SMTP) -----
# For development, use SMTP_HOST=test to use Ethereal auto-preview
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=SkyBooker
EMAIL_FROM_ADDRESS=noreply@skybooker.com

# ----- File Uploads -----
UPLOAD_MAX_MB=5
# Uploaded files are served from /uploads — set this for production:
# UPLOAD_BASE_URL=https://cdn.skybooker.com

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ----- CORS -----
CORS_ORIGIN=http://localhost:5173
