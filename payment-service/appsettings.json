{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/payment-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 30
                }
            }
        ]
    },
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Port=3306;Database=skybooker_db;User=root;Password=root;"
    },
    "Razorpay": {
        "KeyId": "YOUR_RAZORPAY_TEST_KEY_ID",
        "KeySecret": "YOUR_RAZORPAY_TEST_KEY_SECRET",
        "WebhookSecret": "YOUR_RAZORPAY_WEBHOOK_SECRET"
    },
    "InternalApiKey": "sk_internal_key_change_in_production",
    "EmailSettings": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,
        "UseSsl": false,
        "Username": "your.email@gmail.com",
        "Password": "your_app_password",
        "FromAddress": "noreply@skybooker.com",
        "FromName": "SkyBooker"
    },
    "AllowedHosts": "*",
    "Urls": "http://localhost:7000"
}